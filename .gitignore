# ============================================================
# Emotional AI Agent — .gitignore
# ============================================================

# Virtual Environment
.venv/
venv/
env/

# Environment secrets — NEVER commit this
.env

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# VS Code settings (optional: some teams commit this, we don't)
.vscode/
*.code-workspace

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Model files — these are large binary files, don't commit them
# They are regenerated by running the training script
models/emotion/distilbert-emotion/*.bin
models/emotion/distilbert-emotion/*.safetensors
models/emotion/distilbert-emotion/optimizer.pt
models/emotion/minilm-emotion/*.bin
models/emotion/minilm-emotion/*.safetensors
models/emotion/minilm-emotion/optimizer.pt

# But DO commit model config files (small JSON/YAML, needed for inference)
!models/emotion/distilbert-emotion/config.json
!models/emotion/distilbert-emotion/tokenizer.json
!models/emotion/minilm-emotion/config.json

# Data files — raw data is downloaded, not committed
data/raw/
data/processed/

# But DO commit data READMEs
!data/README.md

# Database files (contain private conversation data)
data/*.db
data/*.sqlite
data/*.sqlite3

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
tmp/

# Encryption keys — ABSOLUTELY never commit
*.key
*.pem
*.p12
keystore/
