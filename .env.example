# ============================================================
# Emotional AI Agent — Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# --- Application Settings ---
APP_NAME="Emotional AI Agent"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# --- Model Configuration ---
# Options: distilbert, minilm
EMOTION_MODEL_TYPE=distilbert

# Options: phi3:mini, mistral
LLM_MODEL_NAME=phi3:mini

# Ollama server settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# --- Emotion Detection Settings ---
EMOTION_CONFIDENCE_THRESHOLD=0.3
EMOTION_SMOOTHING_WINDOW=4
NUM_EMOTION_CLASSES=8

# --- Storage Settings ---
# Path for the SQLite database (relative to project root)
DATABASE_PATH=data/conversations.db

# Enable Privacy Mode by default (no disk writes)
PRIVACY_MODE_DEFAULT=false

# --- Training Settings ---
TRAIN_BATCH_SIZE=32
TRAIN_EPOCHS=5
TRAIN_LEARNING_RATE=2e-5
TRAIN_MAX_LENGTH=128
TRAIN_WEIGHT_DECAY=0.01
VALIDATION_SPLIT=0.1

# --- Hardware Settings ---
# Options: auto, cpu, mps, cuda
# auto = detect best available device automatically
DEVICE=auto

HF_MINILM_REPO=